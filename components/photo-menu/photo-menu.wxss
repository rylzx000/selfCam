/* 照片操作菜单组件样式 */

.menu-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.menu-container {
  width: 140rpx;
  background-color: #FFFFFF;
  border-radius: 6rpx;
  overflow: hidden;
}

.menu-item {
  height: 45rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 18rpx;
}

.menu-item-delete {
  color: #D32F2F;
}

.menu-item-retake {
  color: #81C784;
}

.menu-item:active {
  background-color: #F5F5F5;
}

.menu-divider {
  height: 1rpx;
  background-color: #E0E0E0;
}
