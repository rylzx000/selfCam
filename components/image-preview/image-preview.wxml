<!--图片预览组件-->
<view class="preview-mask" wx:if="{{visible}}" bindtap="onClose">
  <!-- 内容容器 -->
  <view class="preview-content" catchtap="stopPropagation">
    <!-- 图片 -->
    <image 
      class="preview-image" 
      src="{{currentImage}}" 
      mode="aspectFit"
    ></image>
    
    <!-- 右侧按钮 -->
    <view class="side-actions">
      <view class="action-btn action-delete" bindtap="onDelete">
        <text>删除</text>
      </view>
      <view class="action-btn action-retake" bindtap="onRetake">
        <text>重拍</text>
      </view>
    </view>
  </view>
</view>
