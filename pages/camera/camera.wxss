/* 鎷嶇収椤垫牱寮?*/

.container {
  width: 100%;
  height: 100%;
  background: linear-gradient(135deg, #FAFAFA 0%, #F0F0F0 100%);
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: center;
  padding: 20rpx 32rpx;
  box-sizing: border-box;
  gap: 24rpx;
}

/* 宸︿晶淇℃伅鍖?*/
.info-area {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  flex-shrink: 0;
  width: 120rpx;
}

.vehicle-info,
.step-info {
  background-color: #FFFFFF;
  border-radius: 8rpx;
  padding: 14rpx 12rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.06);
  display: flex;
  flex-direction: column;
  align-items: center;
}

.vehicle-label,
.step-label {
  font-size: 12rpx;
  color: #9E9E9E;
  margin-bottom: 4rpx;
}

.vehicle-name {
  font-size: 18rpx;
  color: #212121;
  font-weight: 500;
  white-space: nowrap;
}

.step-name {
  font-size: 16rpx;
  color: #4CAF50;
  font-weight: 500;
  white-space: nowrap;
}

/* 鏌ョ湅宸叉媿鎸夐挳 */
.preview-btn {
  background-color: #4CAF50;
  border-radius: 8rpx;
  padding: 10rpx 12rpx;
  box-shadow: 0 2rpx 8rpx rgba(76, 175, 80, 0.3);
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.2s ease;
}

.preview-text {
  font-size: 14rpx;
  color: #FFFFFF;
  font-weight: 500;
}

.preview-btn:active {
  opacity: 0.8;
  transform: scale(0.98);
}

/* 杞︽崯鎷嶆憚杩涘害淇℃伅 */
.damage-info {
  background-color: #FFFFFF;
  border-radius: 8rpx;
  padding: 14rpx 12rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.06);
  display: flex;
  flex-direction: column;
  align-items: center;
}

.damage-count {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 6rpx;
}

.count-label {
  font-size: 12rpx;
  color: #9E9E9E;
}

.count-value {
  font-size: 18rpx;
  color: #4CAF50;
  font-weight: 600;
}

.damage-tip {
  text-align: center;
}

.damage-tip text {
  font-size: 12rpx;
  color: #757575;
}

/* 瀹屾垚鎷嶆憚鎸夐挳 */
.finish-btn {
  background-color: #FFFFFF;
  border: 2rpx solid #4CAF50;
  border-radius: 8rpx;
  padding: 10rpx 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.2s ease;
}

.finish-text {
  font-size: 14rpx;
  color: #4CAF50;
  font-weight: 500;
}

.finish-btn:active {
  background-color: #E8F5E9;
  transform: scale(0.98);
}

/* 鎷嶇収鍖哄煙 */
.camera-wrapper {
  width: 400rpx;
  height: 300rpx;
  border-radius: 12rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.12);
  background-color: #FFFFFF;
  flex-shrink: 0;
}

.camera {
  width: 100%;
  height: 100%;
}

/* 杈呭姪妗嗗鍣?*/
.guide-container {
  width: 100%;
  height: 100%;
  position: relative;
}

/* 鎻愮ず鏂囧瓧 - 鍥哄畾鍦ㄩ《閮?*/
.guide-tip {
  background-color: rgba(0, 0, 0, 0.55);
  color: #FFFFFF;
  font-size: 16rpx;
  padding: 6rpx 14rpx;
  border-radius: 14rpx;
  position: absolute;
  top: 12rpx;
  left: 50%;
  transform: translateX(-50%);
  white-space: nowrap;
  z-index: 4;
}

.damage-debug {
  position: absolute;
  top: 44rpx;
  left: 50%;
  transform: translateX(-50%);
  background-color: rgba(0, 0, 0, 0.45);
  color: rgba(255, 255, 255, 0.92);
  font-size: 12rpx;
  padding: 4rpx 12rpx;
  border-radius: 12rpx;
  white-space: nowrap;
  z-index: 4;
}

.ai-tip {
  position: absolute;
  left: 50%;
  bottom: 14rpx;
  transform: translateX(-50%);
  background-color: rgba(33, 33, 33, 0.72);
  color: #FFFFFF;
  font-size: 14rpx;
  padding: 6rpx 16rpx;
  border-radius: 14rpx;
  white-space: nowrap;
  border: 1rpx solid rgba(255, 255, 255, 0.18);
  z-index: 4;
}

.ai-tip-locked {
  background-color: rgba(76, 175, 80, 0.92);
  box-shadow: 0 0 0 2rpx rgba(76, 175, 80, 0.24);
}


/* 杈呭姪妗嗗熀纭€鏍峰紡 */
.guide-frame {
  border: 4rpx solid #4CAF50;
  position: absolute;
  box-shadow: 0 0 0 2rpx rgba(76, 175, 80, 0.26);
}

/* 杞︾墝杈呭姪妗?*/
.guide-frame-license {
  width: 200rpx;
  height: 68rpx;
  border-radius: 6rpx;
  bottom: 56rpx;
  left: 50%;
  transform: translateX(-50%);
}

.guide-frame-license-detected {
  border-color: #FFB300;
  box-shadow: 0 0 0 2rpx rgba(255, 179, 0, 0.24);
  background-color: rgba(255, 179, 0, 0.08);
}

.guide-frame-license-stable {
  border-color: #29B6F6;
  box-shadow: 0 0 0 2rpx rgba(41, 182, 246, 0.26);
  background-color: rgba(41, 182, 246, 0.08);
}

.guide-frame-license-locked {
  border-color: #1565C0;
  box-shadow: 0 0 0 3rpx rgba(21, 101, 192, 0.28);
  background-color: rgba(21, 101, 192, 0.10);
}

.plate-distance-hint {
  position: absolute;
  left: 50%;
  bottom: 126rpx;
  transform: translateX(-50%);
  width: 184rpx;
  height: 92rpx;
  z-index: 4;
  pointer-events: none;
}

.plate-distance-arrows {
  position: absolute;
  left: 50%;
  top: 0;
  transform: translateX(-50%);
  width: 184rpx;
  height: 92rpx;
}

.plate-distance-frame {
  position: absolute;
  left: 0;
  top: 0;
  width: 100%;
  height: 100%;
}

.plate-distance-arrow {
  position: absolute;
  left: 50%;
  width: 148rpx;
  height: 24rpx;
  transform: translateX(-50%);
}

.plate-distance-arrow-1 {
  top: 60rpx;
}

.plate-distance-arrow-2 {
  top: 48rpx;
}

.plate-distance-arrow-3 {
  top: 36rpx;
}

.plate-distance-arrow-4 {
  top: 24rpx;
}

.plate-distance-arrow-5 {
  top: 12rpx;
}

.plate-distance-arrow-6 {
  top: 0;
}



/* 璺濈寮曞绠ご娴?*/
.guide-frame-vin {
  width: 320rpx;
  height: 40rpx;
  border-radius: 4rpx;
  bottom: 50rpx;
  left: 50%;
  transform: translateX(-50%);
}

/* 杞︽崯杈呭姪妗?*/
.guide-frame-damage {
  width: 132rpx;
  height: 132rpx;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  position: absolute;
}

.guide-frame-damage-active {
  border-color: #29B6F6;
  box-shadow: 0 0 0 2rpx rgba(41, 182, 246, 0.24);
  background-color: rgba(41, 182, 246, 0.08);
}

.guide-frame-damage-locked {
  border-color: #1565C0;
  box-shadow: 0 0 0 3rpx rgba(21, 101, 192, 0.28);
  background-color: rgba(21, 101, 192, 0.10);
}

.damage-distance-hint {
  position: absolute;
  left: 50%;
  top: 26rpx;
  transform: translateX(-50%);
  width: 164rpx;
  height: 64rpx;
  z-index: 4;
  pointer-events: none;
}

.damage-distance-arrows {
  position: absolute;
  left: 50%;
  top: 0;
  transform: translateX(-50%);
  width: 164rpx;
  height: 64rpx;
}

.damage-distance-frame {
  position: absolute;
  left: 0;
  top: 0;
  width: 100%;
  height: 100%;
}

.damage-distance-arrow {
  position: absolute;
  left: 50%;
  width: 132rpx;
  height: 20rpx;
  transform: translateX(-50%);
}

.damage-distance-arrow-1 {
  top: 44rpx;
}

.damage-distance-arrow-2 {
  top: 35rpx;
}

.damage-distance-arrow-3 {
  top: 26rpx;
}

.damage-distance-arrow-4 {
  top: 17rpx;
}

.damage-distance-arrow-5 {
  top: 8rpx;
}

.damage-distance-arrow-6 {
  top: 0;
}

/* 鍗佸瓧鍑嗘槦 */
.cross-h {
  width: 24rpx;
  height: 2rpx;
  background-color: rgba(255, 255, 255, 0.5);
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
}

.cross-v {
  width: 2rpx;
  height: 24rpx;
  background-color: rgba(255, 255, 255, 0.5);
  position: absolute;
  left: 50%;
  top: 50%;
  transform: translate(-50%, -50%);
}

/* 鍙充晶鎿嶄綔鍖?*/
.action-area {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  width: 120rpx;
}

/* 鎷嶇収鎸夐挳鍖?*/
.capture-section {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.capture-btn {
  width: 76rpx;
  height: 76rpx;
  background-color: #FFFFFF;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 2rpx 12rpx rgba(76, 175, 80, 0.4);
  transition: all 0.2s ease;
}

.capture-inner {
  width: 58rpx;
  height: 58rpx;
  background: linear-gradient(135deg, #4CAF50 0%, #388E3C 100%);
  border-radius: 50%;
  transition: transform 0.15s ease;
}

.capture-btn:active .capture-inner {
  transform: scale(0.9);
}

.capture-text {
  font-size: 12rpx;
  color: #9E9E9E;
  margin-top: 8rpx;
  white-space: nowrap;
}

/* 纭鍖?*/
.confirm-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  background-color: #FFFFFF;
  border-radius: 8rpx;
  padding: 14rpx 12rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.06);
}

.confirm-tip {
  font-size: 14rpx;
  color: #212121;
  margin-bottom: 12rpx;
  text-align: center;
  line-height: 1.4;
  white-space: nowrap;
}

.btn-group {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.btn-retake,
.btn-confirm {
  width: 80rpx;
  height: 36rpx;
  border-radius: 18rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 14rpx;
  transition: all 0.2s ease;
}

.btn-retake {
  background-color: transparent;
  color: #9E9E9E;
  border: 1rpx solid #EEEEEE;
}

.btn-confirm {
  background: linear-gradient(135deg, #4CAF50 0%, #388E3C 100%);
  color: #FFFFFF;
  font-weight: 500;
  box-shadow: 0 2rpx 8rpx rgba(76, 175, 80, 0.3);
}

.btn-retake:active {
  background-color: #FAFAFA;
  transform: scale(0.98);
}

.btn-confirm:active {
  opacity: 0.9;
  transform: scale(0.98);
}

/* 鐓х墖棰勮 */
.photo-preview {
  width: 100%;
  height: 100%;
}

.preview-image {
  width: 100%;
  height: 100%;
}
