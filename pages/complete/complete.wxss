/* 完成页样式 */

.container {
  width: 100%;
  height: 100%;
  background: linear-gradient(135deg, #4CAF50 0%, #388E3C 100%);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 20rpx;
  box-sizing: border-box;
}

/* 完成图标 */
.success-icon {
  width: 50rpx;
  height: 50rpx;
  background-color: #FFFFFF;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 10rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.15);
}

.success-icon text {
  font-size: 28rpx;
  color: #4CAF50;
}

/* 完成标题 */
.title text {
  font-size: 18rpx;
  color: #FFFFFF;
  font-weight: 500;
}

/* 统计卡片 */
.stats-card {
  background-color: rgba(255, 255, 255, 0.95);
  border-radius: 8rpx;
  padding: 12rpx 24rpx;
  display: flex;
  flex-direction: row;
  align-items: center;
  margin-top: 14rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.1);
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  min-width: 60rpx;
}

.stat-value {
  font-size: 22rpx;
  color: #4CAF50;
  font-weight: 600;
  line-height: 1.2;
}

.stat-label {
  font-size: 12rpx;
  color: #9E9E9E;
  margin-top: 2rpx;
}

.stat-divider {
  width: 1rpx;
  height: 30rpx;
  background-color: #EEEEEE;
  margin: 0 16rpx;
}

/* 提示文字 */
.message {
  margin-top: 10rpx;
}

.message text {
  font-size: 14rpx;
  color: rgba(255, 255, 255, 0.85);
}

/* 底部按钮 */
.bottom-area {
  margin-top: 16rpx;
  display: flex;
  flex-direction: row;
  gap: 12rpx;
}

.btn {
  width: 100rpx;
  height: 34rpx;
  border-radius: 17rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 2rpx 6rpx rgba(0, 0, 0, 0.15);
  transition: all 0.2s ease;
}

.btn-primary {
  background-color: #FFFFFF;
}

.btn-primary text {
  color: #4CAF50;
  font-size: 14rpx;
  font-weight: 500;
}

.btn-secondary {
  background-color: transparent;
  border: 1rpx solid rgba(255, 255, 255, 0.6);
  box-shadow: none;
}

.btn-secondary text {
  color: #FFFFFF;
  font-size: 14rpx;
}

.btn:active {
  opacity: 0.8;
  transform: scale(0.98);
}
