/* 全局样式 */
page {
  width: 100%;
  height: 100%;
  background-color: #FAFAFA;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
}

/* 主色调 */
.primary-color {
  color: #4CAF50;
}

.primary-bg {
  background-color: #4CAF50;
}

/* 辅助色 */
.gray-color {
  color: #757575;
}

.gray-bg {
  background-color: #FAFAFA;
}

/* 通用按钮样式 */
.btn-primary {
  background-color: #4CAF50;
  color: #FFFFFF;
  border-radius: 12rpx;
  text-align: center;
  font-size: 32rpx;
  transition: all 0.2s ease;
}

.btn-primary:active {
  opacity: 0.8;
  transform: scale(0.98);
}

.btn-secondary {
  background-color: #FFFFFF;
  color: #757575;
  border: 2rpx solid #EEEEEE;
  border-radius: 12rpx;
  text-align: center;
  font-size: 28rpx;
  transition: all 0.2s ease;
}

.btn-secondary:active {
  opacity: 0.8;
  transform: scale(0.98);
}

.btn-warning {
  background-color: #FF9800;
  color: #FFFFFF;
  border-radius: 12rpx;
  text-align: center;
  font-size: 32rpx;
  transition: all 0.2s ease;
}

.btn-warning:active {
  opacity: 0.8;
  transform: scale(0.98);
}

/* Flex 布局 */
.flex-row {
  display: flex;
  flex-direction: row;
}

.flex-column {
  display: flex;
  flex-direction: column;
}

.flex-center {
  display: flex;
  align-items: center;
  justify-content: center;
}

.flex-between {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

/* 安全区域 */
.safe-area {
  padding-left: 32rpx;
  padding-right: 32rpx;
  padding-top: 24rpx;
  padding-bottom: 24rpx;
}
